{
  "name": "SVG to PNG",
  "version": "1.0.0",
  "description": "Auto-generate banner.png when banner.svg is edited",
  "when": {
    "type": "fileEdited",
    "patterns": [".github/assets/banner.svg"]
  },
  "then": {
    "type": "runCommand",
    "command": "rsvg-convert .github/assets/banner.svg -w 1200 -o .github/assets/banner.png"
  }
}
