{
  "name": "@stackra/mono-cli",
  "version": "0.1.0",
  "description": "Universal CLI for managing Stackra monorepos — clean, build, lint, scaffold, sync, and publish across all ecosystems.",
  "type": "module",
  "bin": {
    "mono": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules/.cache",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "keywords": [
    "cli",
    "monorepo",
    "turborepo",
    "stackra",
    "workspace",
    "scaffold",
    "cleanup"
  ],
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/mono-cli.git"
  },
  "homepage": "https://github.com/stackra-inc/mono-cli#readme",
  "bugs": {
    "url": "https://github.com/stackra-inc/mono-cli/issues"
  },
  "dependencies": {
    "commander": "14.0.3",
    "chalk": "5.6.2",
    "@clack/prompts": "1.3.0",
    "execa": "9.6.1",
    "glob": "13.0.6",
    "cli-table3": "0.6.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
